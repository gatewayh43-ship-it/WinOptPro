{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinOpt Pro",
  "version": "1.0.0",
  "identifier": "com.winoptpro.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WinOpt Pro",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "WinOpt Pro",
    "category": "Utility",
    "copyright": "© 2026 WinOpt Pro",
    "shortDescription": "Windows system optimizer for power users",
    "longDescription": "WinOpt Pro is a comprehensive Windows optimization suite featuring 160+ system tweaks, privacy controls, performance tuning, gaming optimizations, and real-time system monitoring. Built with Tauri 2, React 19, and Rust.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "language": "1033",
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_YOUR_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/user/WinOptPro/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installerArgs": ["/passive"]
      }
    }
  }
}
